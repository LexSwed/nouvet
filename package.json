    "@remix-run/serve": "^2.4.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/better-sqlite3": "^7.6.8",
    "@unpic/react": "^0.1.5",
    "arctic": "^0.10.2",
    "better-sqlite3": "^9.2.2",
    "class-variance-authority": "^0.7.0",
    "drizzle-orm": "^0.29.1",
    "i18next": "^23.7.11",
